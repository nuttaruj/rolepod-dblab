{
  "name": "@rolepod/dblab",
  "version": "0.1.0",
  "description": "Data-layer safety + truth verifier for AI agents — MCP server + shipped skills. Introspect schema, assert DB state as verify-evidence, read query plans, detect schema drift, and mutate data behind a transaction-confirm guard.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "postgres",
    "database",
    "schema-drift",
    "claude-code",
    "rolepod"
  ],
  "homepage": "https://github.com/nuttaruj/rolepod-dblab",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuttaruj/rolepod-dblab.git"
  },
  "license": "MIT",
  "author": "nuttaruj",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "rolepod-dblab": "dist/bin/rolepod-dblab.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "skills/",
    "src/drift/reflect_models.py",
    ".claude-plugin/",
    ".cursor-plugin/",
    ".codex-plugin/",
    "gemini-extension.json",
    ".mcp.json",
    "README.md",
    "LICENSE",
    "THIRD_PARTY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup && npm run build:schemas",
    "build:schemas": "node scripts/export-schemas.mjs",
    "prepublishOnly": "npm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke",
    "smoke:mcp": "node tests/smoke/mcp_handshake.mjs",
    "start": "node dist/bin/rolepod-dblab.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7",
    "zod-to-json-schema": "^3.25.2"
  }
}
